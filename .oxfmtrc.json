{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 140,
  "quoteProps": "consistent",
  "sortImports": {
    "sortSideEffects": true
  },
  "sortTailwindcss": {
    "stylesheet": "./app/globals.css",
    "attributes": ["class", "className"],
    "functions": ["clsx", "cn", "cva"]
  },
  "ignorePatterns": [
    ".next",
    ".turbo",
    "dist",
    "docs",
    "node_modules",
    "pnpm-lock.yaml",
    "src/drizzle/migrations",
    "src/components/ui",
    "drizzle/migrations",
    "components/ui"
  ]
}
