{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "JSON Schema reference for IDE validation and autocomplete",
      "type": "string"
    },
    "version": {
      "description": "Configuration schema version for future migrations",
      "type": "number"
    },
    "configUrl": {
      "default": "https://raw.githubusercontent.com/bai/dev/refs/heads/main/config.json",
      "description": "Remote URL to fetch shared configuration from\n\ndefault: `https://raw.githubusercontent.com/bai/dev/refs/heads/main/config.json`",
      "type": "string",
      "format": "uri",
      "examples": ["https://raw.githubusercontent.com/bai/dev/refs/heads/main/config.json"]
    },
    "defaultOrg": {
      "default": "acmesoftware",
      "description": "Default organization for repository operations\n\ndefault: `acmesoftware`",
      "type": "string",
      "examples": ["acmesoftware"]
    },
    "defaultProvider": {
      "default": "github",
      "description": "Default git provider when not specified (github or gitlab)\n\ndefault: `github`",
      "type": "string",
      "enum": ["github", "gitlab"],
      "examples": ["github"]
    },
    "baseSearchPath": {
      "default": "~/src",
      "description": "Base directory for searching and cloning repositories\n\ndefault: `~/src`",
      "type": "string",
      "examples": ["~/src"]
    },
    "logLevel": {
      "default": "info",
      "description": "Logging verbosity: debug, info, warning, error, or fatal\n\ndefault: `info`",
      "type": "string",
      "enum": ["debug", "info", "warning", "error", "fatal"],
      "examples": ["info"]
    },
    "telemetry": {
      "default": {
        "mode": "disabled"
      },
      "description": "Telemetry mode: 'console' for local output, 'axiom' for Axiom export, 'disabled' to turn off",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "disabled"
            },
            "axiom": {
              "type": "object",
              "properties": {
                "endpoint": {
                  "type": "string",
                  "format": "uri",
                  "description": "Axiom OTLP traces endpoint"
                },
                "apiKey": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Axiom API key used for OTLP trace ingestion"
                },
                "dataset": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Axiom dataset used for trace ingestion"
                }
              },
              "required": ["endpoint", "apiKey", "dataset"],
              "description": "Axiom OTLP exporter settings",
              "additionalProperties": false
            }
          },
          "required": ["mode"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "console"
            },
            "axiom": {
              "type": "object",
              "properties": {
                "endpoint": {
                  "type": "string",
                  "format": "uri",
                  "description": "Axiom OTLP traces endpoint"
                },
                "apiKey": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Axiom API key used for OTLP trace ingestion"
                },
                "dataset": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Axiom dataset used for trace ingestion"
                }
              },
              "required": ["endpoint", "apiKey", "dataset"],
              "description": "Axiom OTLP exporter settings",
              "additionalProperties": false
            }
          },
          "required": ["mode"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "axiom"
            },
            "axiom": {
              "type": "object",
              "properties": {
                "endpoint": {
                  "type": "string",
                  "format": "uri",
                  "description": "Axiom OTLP traces endpoint"
                },
                "apiKey": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Axiom API key used for OTLP trace ingestion"
                },
                "dataset": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Axiom dataset used for trace ingestion"
                }
              },
              "required": ["endpoint", "apiKey", "dataset"],
              "description": "Axiom OTLP exporter settings",
              "additionalProperties": false
            }
          },
          "required": ["mode", "axiom"],
          "additionalProperties": false
        }
      ]
    },
    "orgToProvider": {
      "default": {},
      "description": "Map organization names to their git provider (e.g., { 'mycompany': 'gitlab' }); organization keys are matched case-insensitively",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string",
        "enum": ["github", "gitlab"]
      }
    },
    "miseGlobalConfig": {
      "description": "Mise configuration applied globally ($XDG_CONFIG_HOME/mise)",
      "allOf": [
        {
          "$ref": "https://mise.jdx.dev/schema/mise.json"
        }
      ]
    },
    "miseRepoConfig": {
      "description": "Mise configuration applied per-repository (.mise.toml)",
      "allOf": [
        {
          "$ref": "https://mise.jdx.dev/schema/mise.json"
        }
      ]
    },
    "services": {
      "default": {},
      "description": "Docker services to enable. Include a service key to enable it",
      "type": "object",
      "properties": {
        "postgres17": {
          "description": "PostgreSQL 17 database service",
          "type": "object",
          "properties": {
            "port": {
              "description": "Local host port to expose the service on",
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "additionalProperties": {}
        },
        "postgres18": {
          "description": "PostgreSQL 18 database service",
          "type": "object",
          "properties": {
            "port": {
              "description": "Local host port to expose the service on",
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "additionalProperties": {}
        },
        "valkey": {
          "description": "Valkey (Redis-compatible) cache service",
          "type": "object",
          "properties": {
            "port": {
              "description": "Local host port to expose the service on",
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "additionalProperties": {}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allowComments": true,
  "allowTrailingCommas": true
}
